{
  "name": "@brutils/core",
  "type": "module",
  "version": "1.0.0",
  "description": "TypeScript library for brazilian business utilities",
  "author": "Paulo Henrique <pauloh1288@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/youphenrique/brutils#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youphenrique/brutils.git"
  },
  "bugs": {
    "url": "https://github.com/youphenrique/brutils/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
